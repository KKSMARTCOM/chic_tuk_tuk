{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "build:css": "tailwindcss -i resources/css/app.css -o public/css/app.css --minify",
        "watch:css": "tailwindcss -i resources/css/app.css -o public/css/app.css --watch",
        "dev:all": "concurrently \"npm run watch:css\" \"npm run dev\"",
        "build:all": "npm run build && npm run build:css"
    },
    "devDependencies": {
        "autoprefixer": "^10.4.20",
        "axios": "^1.7.4",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^1.0",
        "postcss": "^8.4.47",
        "tailwindcss": "^3.4.13",
        "vite": "^6.0"
    }
}
